{
  "name": "ai-roundtable-room",
  "version": "1.0.9",
  "description": "A production-ready AI roundtable room for multi-perspective meeting generation.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "node server/index.js",
    "build": "vite build",
    "start": "node server/start-production.js",
    "test": "vitest run",
    "doctor": "node server/doctor.js",
    "check": "npm test && npm run build && npm audit --audit-level=moderate",
    "preview": "npm run build && npm run start",
    "video:studio": "remotion studio remotion/index.jsx",
    "video:still": "remotion still remotion/index.jsx RoundtableExplainer artifacts/roundtable-explainer-frame.png --frame=430",
    "video:render": "remotion render remotion/index.jsx RoundtableExplainer artifacts/roundtable-explainer.mp4",
    "video:gif": "remotion render remotion/index.jsx RoundtableExplainer artifacts/roundtable-explainer-preview.gif --codec=gif --scale=0.35 --every-nth-frame=3"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "openai": "^6.12.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.3.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.462",
    "remotion": "^4.0.462",
    "vitest": "^4.0.16"
  },
  "overrides": {
    "ws": "8.20.1"
  }
}
