# =============================================================================
# AI 圆桌会议室 .env
# =============================================================================
# 使用方法：
#   1. 复制本文件为 .env
#   2. 至少填写一个供应商的 API_KEY
#   3. 运行 npm run doctor 检查配置
#
# 最小可用配置只需要看 STEP 1。
# =============================================================================


# =============================================================================
# STEP 1 - 最小可用配置
# =============================================================================
# 供应商顺序决定角色轮流使用模型的顺序。只用一个供应商时保持 openai 即可。
AI_PROVIDERS=openai

# API Key：必填。
OPENAI_API_KEY=

# Base URL：直连 OpenAI 官方时留空；使用中转/兼容服务时填写，例如 https://api.example.com/v1
OPENAI_BASE_URL=

# 模型名：按你的供应商实际支持的模型填写。
OPENAI_MODEL=gpt-5.5

# 单次最大输出 token 数，不是模型上下文窗口。圆桌 JSON 建议保持 8192。
OPENAI_MAX_TOKENS=8192


# =============================================================================
# STEP 2 - 可选：访问控制和额度
# =============================================================================
# 本地自用可以留空。公开部署时建议设置访问码，避免别人消耗你的模型额度。
APP_ACCESS_CODE=

# 生产环境建议设置随机长字符串：
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

SESSION_MAX_AGE_HOURS=12
DAILY_MEETING_LIMIT=80


# =============================================================================
# STEP 3 - 可选：服务端口
# =============================================================================
PORT=5173


# =============================================================================
# STEP 4 - 可选：DeepSeek
# =============================================================================
# 启用方法：把 AI_PROVIDERS 改成 openai,deepseek 或 deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=4096


# =============================================================================
# STEP 5 - 可选：智谱 GLM
# =============================================================================
# 启用方法：把 AI_PROVIDERS 改成 openai,glm 或 glm
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.5
GLM_MAX_TOKENS=8192


# =============================================================================
# STEP 6 - 可选：小米 MiMo
# =============================================================================
# 启用方法：把 AI_PROVIDERS 改成 openai,xiaomi 或 xiaomi
XIAOMI_API_KEY=
XIAOMI_BASE_URL=https://api.mimo-v2.com/v1
XIAOMI_MODEL=mimo-v2.5-pro
XIAOMI_MAX_TOKENS=8192


# =============================================================================
# STEP 7 - 可选：Claude
# =============================================================================
# 启用方法：把 AI_PROVIDERS 改成 openai,claude 或 claude，并保留 CLAUDE_TYPE=claude
CLAUDE_API_KEY=
CLAUDE_TYPE=claude
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-5-20250929
CLAUDE_API_VERSION=2023-06-01
CLAUDE_MAX_TOKENS=8192


# =============================================================================
# STEP 8 - 可选：自定义 OpenAI 兼容接口
# =============================================================================
# 例：
# AI_PROVIDERS=custom1
# CUSTOM1_API_KEY=
# CUSTOM1_BASE_URL=https://your-openai-compatible-host/v1
# CUSTOM1_MODEL=your-model-name
# CUSTOM1_MAX_TOKENS=8192


# =============================================================================
# STEP 9 - 可选：指定角色固定使用某个供应商
# =============================================================================
# 格式：角色ID:供应商名，多个用逗号分隔
# 示例：ROLE_PROVIDERS=li:deepseek,heng:openai,che:glm,zhuo:xiaomi
ROLE_PROVIDERS=

# 留空时默认取 AI_PROVIDERS 里第一个已配置 API Key 的供应商。
PRIMARY_PROVIDER=
